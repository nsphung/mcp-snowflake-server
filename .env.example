# Choose one AUTH type. Details on https://docs.snowflake.com/en/developer-guide/python-connector/python-connector-connect
#
# IMPORTANT: Do NOT quote values and do NOT use inline comments.
# Both break `docker run --env-file` compatibility.
# Correct:   VAR=value
# Incorrect: VAR="value"   or   VAR=value # comment

#####################################################
## Auth user external browser #######################
#####################################################
SNOWFLAKE_AUTHENTICATOR=externalbrowser
SNOWFLAKE_USER=USER_EMAIL
####################################################

#####################################################
##### Auth Key Pair #################################
#####################################################
# SNOWFLAKE_AUTHENTICATOR=SNOWFLAKE_JWT
# SNOWFLAKE_USER=USER
# SNOWFLAKE_PRIVATE_KEY_FILE=file.pem
# SNOWFLAKE_PRIVATE_KEY_FILE_PWD=passphrase
#####################################################

######################################################
##### OAuth 2.0 Client Credentials flow ##############
######################################################
# SNOWFLAKE_AUTHENTICATOR=OAUTH_CLIENT_CREDENTIALS
# SNOWFLAKE_OAUTH_CLIENT_ID=oauth_client_id
# SNOWFLAKE_OAUTH_CLIENT_SECRET=oauth_client_secret
# SNOWFLAKE_OAUTH_TOKEN_REQUEST_URL=oauth_token_request_url
# SNOWFLAKE_OAUTH_SCOPE=oauth_scope
######################################################

######################################################
##### Common conf ####################################
######################################################
SNOWFLAKE_ACCOUNT=ACCOUNT
SNOWFLAKE_ROLE=ROLE
SNOWFLAKE_DATABASE=DATABASE
SNOWFLAKE_SCHEMA=SCHEMA
SNOWFLAKE_WAREHOUSE=WAREHOUSE
######################################################
